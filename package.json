{
  "name": "prompt-caster",
  "displayName": "PromptCaster",
  "description": "Boost developer productivity with instant AI prompt shortcuts and customizable templates directly in your editor.",
  "version": "1.0.1",
  "publisher": "devDhrubo",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/devDhrubo/promptforge.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:html",
    "onLanguage:css",
    "onLanguage:python",
    "onLanguage:go",
    "onLanguage:rust",
    "onLanguage:java",
    "onLanguage:cpp",
    "onCommand:promptCaster.openLibrary"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptCaster.openLibrary",
        "title": "PromptCaster: Open Prompt Library",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.copyPrompt",
        "title": "PromptCaster: Copy Prompt to Clipboard",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.review",
        "title": "PromptCaster: Review Code",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.bug",
        "title": "PromptCaster: Bug Analysis",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.test",
        "title": "PromptCaster: Generate Tests",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.explain",
        "title": "PromptCaster: Explain Code",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.clean",
        "title": "PromptCaster: Clean/Refactor Code",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.readme",
        "title": "PromptCaster: Generate README.md",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.optimize",
        "title": "PromptCaster: Optimize Performance",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.refactor",
        "title": "PromptCaster: Refactor Code",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.document",
        "title": "PromptCaster: Document Code",
        "category": "PromptCaster"
      },
      {
        "command": "promptCaster.security",
        "title": "PromptCaster: Security Audit",
        "category": "PromptCaster"
      }
    ],
    "keybindings": [
      {
        "command": "promptCaster.review",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "promptCaster.bug",
        "key": "ctrl+alt+b",
        "mac": "cmd+alt+b",
        "when": "editorTextFocus"
      },
      {
        "command": "promptCaster.test",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t",
        "when": "editorTextFocus"
      },
      {
        "command": "promptCaster.explain",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      },
      {
        "command": "promptCaster.clean",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "PromptCaster",
      "properties": {
        "promptCaster.customPrompts": {
          "type": "array",
          "default": [
            {
              "name": "Angular Review",
              "prompt": "Review this Angular code and look for component structure issues:\n\n{{selectedCode}}\n\nProvide recommendations.",
              "category": "Frontend"
            }
          ],
          "description": "User custom PromptCaster templates with placeholder {{selectedCode}}.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name of your custom prompt."
              },
              "prompt": {
                "type": "string",
                "description": "The prompt text. Use {{selectedCode}} as variable for selected code."
              },
              "category": {
                "type": "string",
                "default": "AI Development",
                "description": "The category for this prompt (Frontend, Backend, DevOps, Testing, Documentation, AI Development)."
              }
            },
            "required": [
              "name",
              "prompt"
            ]
          }
        },
        "promptCaster.enableSlashCommands": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic expansion of slash commands (e.g., typing /review) in the editor."
        },
        "promptCaster.previewBeforeInsertion": {
          "type": "boolean",
          "default": true,
          "description": "Show the prompt preview window with copy option before inserting it into the editor."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js",
    "compile": "tsc -b",
    "watch": "tsc -b -w",
    "bundle": "node esbuild.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.17.19",
    "typescript": "^4.9.5"
  }
}
